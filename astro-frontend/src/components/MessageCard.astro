---
const { message } = Astro.props;

const firstLetter =
  (
    message.name ||
    "A"
  )[0].toUpperCase();

const formattedDate =
  new Date(
    message.created_at + "Z"
  ).toLocaleString(
    "en-IN",
    {
      timeZone:
        "Asia/Kolkata",

      day:
        "numeric",

      month:
        "short",

      year:
        "numeric",

      hour:
        "numeric",

      minute:
        "2-digit",

      hour12:
        true,
    }
  );
---

<div class="message-card">

  <div class="avatar">
    {firstLetter}
  </div>

  <div class="message-content">

    <div class="message-header">

      <div class="message-name">
        {message.name || "Anonymous"}
      </div>

      <div class="message-date">
        {formattedDate}
      </div>

    </div>

    <div class="message-text">
      {message.message}
    </div>

  </div>

</div>