---
const API_URL =
  import.meta.env.PUBLIC_API_URL;
---

<div class="form-card">

  <form id="feedbackForm">

    <input
      type="text"
      name="name"
      placeholder="Your name (optional)"
    />

    <textarea
      id="messageInput"
      name="message"
      maxlength="300"
      placeholder="Write your feedback..."
      required
    ></textarea>

    <div class="counter">
      <span id="charCount">
        0
      </span>
      / 300 characters
    </div>

    <button id="submitBtn">
      Submit Feedback
    </button>

  </form>

</div>

<div
  id="toast"
  class="toast"
  style="display:none;"
>
  Feedback submitted!
</div>

<script define:vars={{ API_URL }}>

  const form =
    document.getElementById(
      "feedbackForm"
    );

  const textarea =
    document.getElementById(
      "messageInput"
    );

  const charCount =
    document.getElementById(
      "charCount"
    );

  const submitBtn =
    document.getElementById(
      "submitBtn"
    );

  const toast =
    document.getElementById(
      "toast"
    );

  function formatDate(dateString) {

    return new Date(
      dateString
    ).toLocaleString(
      "en-IN",
      {
        timeZone:
          "Asia/Kolkata",

        day:
          "numeric",

        month:
          "short",

        year:
          "numeric",

        hour:
          "numeric",

        minute:
          "2-digit",

        hour12:
          true,
      }
    );
  }

  // Character counter
  textarea.addEventListener(
    "input",
    () => {

      charCount.textContent =
        textarea.value.length;

    }
  );

  // Submit form
  form.addEventListener(
    "submit",
    async (e) => {

      e.preventDefault();

      submitBtn.disabled = true;

      submitBtn.textContent =
        "Submitting...";

      const formData =
        new FormData(form);

      const payload = {
        name:
          formData.get("name"),

        message:
          formData.get("message"),
      };

      try {

        const response =
          await fetch(
            `${API_URL}/api/submit`,
            {
              method: "POST",

              headers: {
                "Content-Type":
                  "application/json",
              },

              body:
                JSON.stringify(
                  payload
                ),
            }
          );

        // Rate limit handling
        if (
          response.status === 429
        ) {

          const data =
            await response.json();

          toast.textContent =
            data.error;

          toast.style.display =
            "block";

          setTimeout(() => {

            toast.style.display =
              "none";

            toast.textContent =
              "Feedback submitted!";

          }, 3000);

          submitBtn.disabled =
            false;

          submitBtn.textContent =
            "Submit Feedback";

          return;
        }

        if (response.ok) {

          const result =
            await response.json();

          if (!result.message) {

            console.error(
              "No message returned from API"
            );

            return;
          }

          const feedback =
            result.message;

          toast.textContent =
            "Feedback submitted!";

          toast.style.display =
            "block";

          form.reset();

          charCount.textContent =
            "0";

          const feedbackList =
            document.getElementById(
              "feedbackList"
            );

          if (!feedbackList) {

            console.error(
              "feedbackList container not found"
            );

            return;
          }

          // Remove empty state
          const emptyState =
            feedbackList.querySelector(
              ".empty-state"
            );

          if (emptyState) {

            emptyState.remove();
          }

          const firstLetter =
            (
              feedback.name ||
              "A"
            )[0].toUpperCase();

          const formattedDate =
            formatDate(
              feedback.created_at
            );

          const newMessage =
            document.createElement(
              "div"
            );

          newMessage.className =
            "message-card";

          newMessage.innerHTML = `
            <div class="avatar">
              ${firstLetter}
            </div>

            <div class="message-content">

              <div class="message-header">

                <div class="message-name">
                  ${feedback.name}
                </div>

                <div class="message-date">
                  ${formattedDate}
                </div>

              </div>

              <div class="message-text">
                ${feedback.message}
              </div>

            </div>
          `;

          feedbackList.prepend(
            newMessage
          );

          setTimeout(() => {

            toast.style.display =
              "none";

          }, 2000);

        }

      } catch (error) {

        console.error(error);

        toast.textContent =
          "Something went wrong";

        toast.style.display =
          "block";

        setTimeout(() => {

          toast.style.display =
            "none";

          toast.textContent =
            "Feedback submitted!";

        }, 3000);
      }

      submitBtn.disabled = false;

      submitBtn.textContent =
        "Submit Feedback";
    }
  );

</script>